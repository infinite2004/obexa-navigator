# Local Development Environment Variables
# Copy this to .env.local and fill in your values

# ============================================================================
# LOCAL DEVELOPMENT - Firestore & GCP
# ============================================================================

# Use Firestore emulator locally (started by docker-compose)
FIRESTORE_EMULATOR_HOST=localhost:8080
GOOGLE_CLOUD_PROJECT=obexa-navigator-local

# ============================================================================
# LOCAL DEVELOPMENT - Services
# ============================================================================

# When running services in docker-compose, use service names
# When running services locally on different ports, use localhost:port

# Orchestrator service address (for executor to call orchestrator)
ORCHESTRATOR_SERVICE_URL=http://localhost:8000

# Executor service address (for orchestrator to call executor)
EXECUTOR_SERVICE_URL=http://localhost:8081

# Frontend API endpoint
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# ============================================================================
# LLM Configuration - Gemini / Vertex AI
# ============================================================================

# Option 1: Using Gemini API (simpler, requires API key)
GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: Using Vertex AI (requires GCP project setup)
# GOOGLE_CLOUD_PROJECT=obexa-navigator-local
# VERTEX_AI_LOCATION=us-central1
# VERTEX_AI_MODEL=gemini-pro

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=DEBUG
NODE_ENV=development

# ============================================================================
# Storage Configuration
# ============================================================================

# For local development, store screenshots in ./screenshots
SCREENSHOT_STORAGE_PATH=./screenshots

# Firestore collection prefix for local dev
FIRESTORE_COLLECTION_PREFIX=obexa-local

# ============================================================================
# Authentication (Local dev - skip auth)
# ============================================================================

# Disable authentication for local development
SKIP_AUTH=true

# Service account credentials are automatically discovered from GOOGLE_APPLICATION_CREDENTIALS
# In local dev, use: export GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# ============================================================================
# Server Ports
# ============================================================================

PORT=8000          # Orchestrator
EXECUTOR_PORT=8080 # Executor
FRONTEND_PORT=3000 # Next.js frontend
